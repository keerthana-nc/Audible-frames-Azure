# =============================================================================
# .gitignore — audible-frames-azure
#
# This file tells git which files to NEVER commit.
# Rule of thumb: if a file contains secrets, is auto-generated, or is
# specific to your machine, it belongs here.
# =============================================================================

# -----------------------------------------------------------------------------
# SECRETS — the most important section
# If .env ever gets committed, rotate all your keys immediately.
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example

# -----------------------------------------------------------------------------
# Python byte-compiled files
# Python creates these automatically when it runs your code. They're machine-
# specific and can always be regenerated — no reason to commit them.
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo

# -----------------------------------------------------------------------------
# Virtual environment
# Your venv/ folder contains a full copy of Python + all packages.
# It's large (~hundreds of MB) and completely reproducible from requirements.txt.
# -----------------------------------------------------------------------------
venv/
env/
.venv/
.env/

# -----------------------------------------------------------------------------
# Audio and image outputs from the pipeline
# Every run of the pipeline produces audio files. We clean these up in code,
# but gitignore is a safety net so they never sneak into a commit.
# -----------------------------------------------------------------------------
*.mp3
*.flac
*.wav
*.ogg
outputs/
temp/
tmp/

# -----------------------------------------------------------------------------
# Test and coverage artifacts
# Generated by pytest — can always be recreated by running tests again.
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover

# -----------------------------------------------------------------------------
# Evaluation outputs
# Phase 3 eval results — large JSON files we don't want in git history.
# The README will summarize the numbers; the raw files stay local.
# -----------------------------------------------------------------------------
evals/results/

# -----------------------------------------------------------------------------
# Distribution / packaging artifacts
# Created when building Python packages — not needed here.
# -----------------------------------------------------------------------------
dist/
build/
*.egg-info/
*.egg
MANIFEST

# -----------------------------------------------------------------------------
# IDE and editor files
# These are specific to your tools (Cursor, VS Code, PyCharm, etc.).
# Other contributors use their own tools — don't force yours on them.
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.cursor/

# -----------------------------------------------------------------------------
# OS-generated files
# Windows Explorer and macOS Finder create these automatically.
# -----------------------------------------------------------------------------
Thumbs.db
Desktop.ini
.DS_Store
.DS_Store?
._*

# -----------------------------------------------------------------------------
# Azure and cloud credentials
# Extra safety net — these should never leave your machine.
# -----------------------------------------------------------------------------
*.publishsettings
ServiceConfiguration.*.cscfg
