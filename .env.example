# =============================================================================
# .env.example — copy this file to .env and fill in your real values.
#
# HOW TO USE:
#   Windows:  copy .env.example .env
#   Mac/Linux: cp .env.example .env
#
# CRITICAL: .env is in .gitignore and must NEVER be committed.
#           If you accidentally commit it, rotate all keys immediately.
#
# WHERE TO FIND THESE VALUES:
#   Azure Portal → your resource → "Keys and Endpoint" (left sidebar)
# =============================================================================


# -----------------------------------------------------------------------------
# Azure OpenAI / AI Foundry
# Region: East US 2 — required for gpt-5.4-mini (only in select regions).
# -----------------------------------------------------------------------------

# Your Azure OpenAI resource endpoint. Looks like:
#   https://YOUR-RESOURCE-NAME.openai.azure.com/
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE_NAME.openai.azure.com/

# One of the two API keys shown under "Keys and Endpoint" in the portal.
AZURE_OPENAI_API_KEY=your-azure-openai-key-here

# The deployment name YOU chose when you deployed the model in Azure AI Foundry.
# (Not the model name — the name you typed in the deployment form.)
# Primary:    gpt-5.4-mini
# Fallback 1: gpt-4o-mini   (if gpt-5.4-mini has no quota)
# Fallback 2: gpt-4o        (last resort)
# Switching is a one-line change here — no code rewrite needed.
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-5.4-mini

# API version string. This controls which Azure OpenAI API features are available.
# Use the preview version to access the latest models.
AZURE_OPENAI_API_VERSION=2025-03-01-preview


# -----------------------------------------------------------------------------
# Azure AI Vision (Image Analysis)
# Used for: dense captions, OCR, object detection
# Recommended tier: F0 (free — 5,000 transactions/month)
# -----------------------------------------------------------------------------

AZURE_VISION_ENDPOINT=https://YOUR_RESOURCE_NAME.cognitiveservices.azure.com/
AZURE_VISION_KEY=your-azure-vision-key-here


# -----------------------------------------------------------------------------
# Azure AI Speech (Text-to-Speech)
# Used for: converting text descriptions to audio
# Recommended tier: F0 (free — 500,000 characters/month)
# Note: region must match where you created the Speech resource.
# -----------------------------------------------------------------------------

AZURE_SPEECH_KEY=your-azure-speech-key-here
AZURE_SPEECH_REGION=eastus2


# -----------------------------------------------------------------------------
# Azure AI Content Safety
# Used for: checking input images and generated text for unsafe content
# Recommended tier: F0 (free — 5,000 transactions/month)
# -----------------------------------------------------------------------------

AZURE_CONTENT_SAFETY_ENDPOINT=https://YOUR_RESOURCE_NAME.cognitiveservices.azure.com/
AZURE_CONTENT_SAFETY_KEY=your-azure-content-safety-key-here


# -----------------------------------------------------------------------------
# Azure Application Insights (Phase 5 — observability)
# Used for: live dashboard of request counts, latency, errors, and cost signals.
# Recommended tier: Free (5GB/month)
#
# HOW TO GET THIS VALUE:
#   Azure Portal → Application Insights resource → Overview → Connection String
#   It looks like: InstrumentationKey=...;IngestionEndpoint=...
#
# OPTIONAL FOR LOCAL DEV: If not set, telemetry is silently disabled.
# REQUIRED FOR PRODUCTION: Set this in your Azure Container Apps environment.
# -----------------------------------------------------------------------------

APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=YOUR_KEY;IngestionEndpoint=https://eastus2-3.in.applicationinsights.azure.com/
